rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidQuestion() {
      let data = request.resource.data;
      return data.title is string
          && data.title.size() >= 10
          && data.title.size() <= 200
          && data.description is string
          && data.description.size() >= 20
          && data.tags is list
          && data.tags.size() >= 1
          && data.tags.size() <= 5;
    }

    function isValidAnswer() {
      let data = request.resource.data;
      return data.content is string && data.content.size() >= 20;
    }

    function isValidComment() {
      let data = request.resource.data;
      return data.content is string
          && data.content.size() >= 1
          && data.content.size() <= 500;
    }

    // ─── Users ───────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Anyone can read profiles
      allow read: if true;

      // Only the user themselves can create/update their profile
      allow create: if isOwner(userId);
      allow update: if isOwner(userId)
                    && !('email' in request.resource.data.diff(resource.data).affectedKeys())
                    && !('uid' in request.resource.data.diff(resource.data).affectedKeys());

      // No one can delete user documents directly
      allow delete: if false;
    }

    // ─── Questions ───────────────────────────────────────────────────────────
    match /questions/{questionId} {
      // Anyone can read questions
      allow read: if true;

      // Only authenticated users can create questions
      allow create: if isSignedIn()
                    && isValidQuestion()
                    && request.resource.data.authorId == request.auth.uid;

      // Authors can update their own questions; any auth user can update vote fields
      allow update: if isSignedIn() && (
        // Author updating content
        resource.data.authorId == request.auth.uid
        ||
        // Any signed-in user updating vote-related fields only
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['votes', 'upvoters', 'downvoters', 'views', 'answersCount', 'isAnswered', 'acceptedAnswerId', 'updatedAt'])
      );

      // Only the author can delete their question
      allow delete: if isOwner(resource.data.authorId);

      // ─── Answers ──────────────────────────────────────────────────────────
      match /answers/{answerId} {
        allow read: if true;

        allow create: if isSignedIn()
                      && isValidAnswer()
                      && request.resource.data.authorId == request.auth.uid;

        allow update: if isSignedIn() && (
          resource.data.authorId == request.auth.uid
          ||
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['votes', 'upvoters', 'downvoters', 'isAccepted', 'updatedAt'])
        );

        allow delete: if isOwner(resource.data.authorId);

        // ─── Comments ───────────────────────────────────────────────────────
        match /comments/{commentId} {
          allow read: if true;

          allow create: if isSignedIn()
                        && isValidComment()
                        && request.resource.data.authorId == request.auth.uid;

          allow update: if isOwner(resource.data.authorId);
          allow delete: if isOwner(resource.data.authorId);
        }
      }
    }
  }
}
